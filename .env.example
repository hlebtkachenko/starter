# Copy this file to `.env.local` (or symlink it; Conductor manages a symlink).
# Production values live in AWS Secrets Manager (see infra/secrets.ts).
# Never commit a populated `.env*`.

# --- App ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Database -----------------------------------------------------------
# Local docker: docker-compose.yml provisions postgres:18 with pgmq + citext.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/<project-name>_dev
POSTGRES_PORT=5432

# --- Auth (Better Auth) -------------------------------------------------
BETTER_AUTH_SECRET=<random-32-bytes-base64>
BETTER_AUTH_URL=http://localhost:3000

# --- Sentry -------------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=<sentry-org>
SENTRY_PROJECT=<sentry-project>
SENTRY_RELEASE=local

# --- SMTP (mailbox-keyed) -----------------------------------------------
# Local: docker mailpit catches all (host=mailpit, port=1025, no auth).
# Prod:  set per-mailbox creds in Secrets Manager; one purpose per mailbox.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false

SMTP_NOREPLY_USER=noreply@<domain>
SMTP_NOREPLY_PASS=
SMTP_SUPPORT_USER=support@<domain>
SMTP_SUPPORT_PASS=
SMTP_ADMIN_USER=admin@<domain>
SMTP_ADMIN_PASS=
SMTP_DEMO_USER=demo@<domain>
SMTP_DEMO_PASS=

# --- AWS / S3 -----------------------------------------------------------
AWS_REGION=<aws-region>
S3_BUCKET=<project-name>-dev-uploads

# --- Stripe (LATER) -----------------------------------------------------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# See docs/conventions/api-conventions.md for env-shape contract.
