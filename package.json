{
  "name": "starter",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "knip": "knip",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "registry:build": "tsx scripts/build-registry.ts",
    "registry:check": "tsx scripts/build-registry.ts && git diff --exit-code -- src/components/__index__.tsx",
    "registry:export": "tsx scripts/generate-showcase-export.ts && tsx scripts/generate-manifest.ts",
    "registry:check-orphans": "tsx scripts/check-orphans.ts",
    "registry:drift-check": "tsx scripts/check-content-drift.ts",
    "db:studio": "drizzle-kit studio",
    "deploy:staging": "sst deploy --stage staging",
    "deploy:prod": "sst deploy --stage prod",
    "pull": "bash scripts/safe-pull.sh",
    "prepare": "lefthook install || true",
    "mcp:registry-server": "tsx src/lib/registry-mcp/server.ts"
  },
  "dependencies": {
    "@ark-ui/react": "5.36.2",
    "@base-ui/react": "1.4.1",
    "@diceui/mention": "0.8.0",
    "@diceui/tags-input": "0.7.2",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@floating-ui/react-dom": "2.1.8",
    "@hookform/resolvers": "5.2.2",
    "@hugeicons/core-free-icons": "4.1.2",
    "@hugeicons/react": "1.1.6",
    "@icons-pack/react-simple-icons": "13.13.0",
    "@radix-ui/react-direction": "1.1.1",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-use-controllable-state": "1.2.2",
    "@tabler/icons-react": "3.43.0",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.24",
    "border-beam": "1.0.1",
    "chrono-node": "2.9.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-autoplay": "8.6.0",
    "embla-carousel-react": "8.6.0",
    "es-toolkit": "1.46.1",
    "input-otp": "1.4.2",
    "lucide-react": "1.14.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.7.284",
    "qrcode": "1.5.4",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-day-picker": "10.0.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.75.0",
    "react-pdf": "10.4.1",
    "react-resizable-panels": "4.11.0",
    "react-textarea-autosize": "8.5.9",
    "recharts": "3.8.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/types": "20.5.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/qrcode": "1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "29.1.1",
    "knip": "6.11.0",
    "lefthook": "2.1.6",
    "shadcn": "4.6.0",
    "tailwindcss": "^4",
    "tsx": "4.21.0",
    "typescript": "^6",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^3.2.4"
  }
}
