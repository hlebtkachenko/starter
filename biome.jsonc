{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignore": [
      "**/.planning",
      "**/.claude",
      "**/.next",
      "**/.turbo",
      "**/.sst",
      "**/node_modules",
      "**/dist",
      "**/build",
      "**/out",
      "**/coverage",
      "db/migrations/meta",
      "next-env.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "semicolons": "always", "trailingCommas": "all" }
  },
  "linter": {
    "enabled": false
  },
  "organizeImports": { "enabled": true }
}
